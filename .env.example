# Grow 環境変数（.env にコピーして使う: cp .env.example .env）

# ランタイムAIの切替: mock（ローカル・テスト、費用ゼロ） / gemini（Vertex AI、本番のみ）
AI_PROVIDER=mock

# PostgreSQL 接続（ローカルは scripts/devdb.sh が port 54329 で起動する）
DATABASE_URL=postgresql://grow:grow@localhost:54329/grow

# GCP（本番デプロイ時のみ設定。ローカル mock 開発では空でよい）
GCP_PROJECT=
GCP_LOCATION=asia-northeast1
CLOUD_TASKS_QUEUE=grow-jobs

# Cloud Tasks が worker エンドポイントへ push する自サービスURL
SELF_URL=http://localhost:8000

# 待受ポート（Cloud Run では自動注入されるため通常設定不要。ローカル既定 8000）
# PORT=8000
